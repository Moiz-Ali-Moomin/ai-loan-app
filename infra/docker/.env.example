# =============================================================
# AI Loan Governance Platform — Docker Compose Environment
# Copy to infra/docker/.env and fill in real values.
# NEVER commit .env to version control.
# =============================================================

# ------------------------------------------------------------------
# VPS / deployment
# ------------------------------------------------------------------
VPS_IP=62.238.25.225
PUBLIC_ORIGIN=http://62.238.25.225

# ------------------------------------------------------------------
# PostgreSQL (application database)
# ------------------------------------------------------------------
POSTGRES_USER=loanapp
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=loandb

# ------------------------------------------------------------------
# PostgreSQL (Temporal database — separate instance)
# ------------------------------------------------------------------
TEMPORAL_POSTGRES_USER=temporal
TEMPORAL_POSTGRES_PASSWORD=change-me-temporal-db-password

# ------------------------------------------------------------------
# JWT
# ------------------------------------------------------------------
# Must be at least 32 characters.  Generate with:
#   openssl rand -hex 32
JWT_SECRET=change-me-super-secret-jwt-key-min-32-chars-here

# ------------------------------------------------------------------
# MinIO
# ------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password

# ------------------------------------------------------------------
# Grafana
# ------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# ------------------------------------------------------------------
# AI / OpenAI
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-replace-with-real-key
AI_MOCK_MODE=true
