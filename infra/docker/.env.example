# =============================================================
# AI Loan Governance Platform — Docker Compose Environment
# Copy to infra/docker/.env and fill in real values.
# NEVER commit .env to version control.
# =============================================================

# ------------------------------------------------------------------
# VPS / deployment
# ------------------------------------------------------------------
VPS_IP=62.238.25.225
PUBLIC_ORIGIN=http://62.238.25.225

# ------------------------------------------------------------------
# PostgreSQL (application database)
# ------------------------------------------------------------------
POSTGRES_USER=loanapp
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=loandb

# ------------------------------------------------------------------
# PostgreSQL (Temporal database — separate instance)
# ------------------------------------------------------------------
TEMPORAL_POSTGRES_USER=temporal
TEMPORAL_POSTGRES_PASSWORD=change-me-temporal-db-password

# ------------------------------------------------------------------
# JWT
# ------------------------------------------------------------------
# Must be at least 32 characters.  Generate with:
#   openssl rand -hex 32
JWT_SECRET=change-me-super-secret-jwt-key-min-32-chars-here

# ------------------------------------------------------------------
# MinIO
# ------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password

# ------------------------------------------------------------------
# Grafana
# ------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# ------------------------------------------------------------------
# AI — Anthropic Claude
# ------------------------------------------------------------------
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-replace-with-real-key
# Set to 'false' to use real Claude, 'true' for deterministic mock
AI_MOCK_MODE=true
AI_MODEL=claude-sonnet-4-6
ACTIVE_PROMPT_VERSION=1.2.0

# ------------------------------------------------------------------
# PII Encryption (AES-256-GCM)
# ------------------------------------------------------------------
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotate by bumping PII_KEY_VERSION and running the re-encryption migration.
PII_ENCRYPTION_KEY=REPLACE_WITH_base64_32_byte_key
PII_KEY_VERSION=1

# ------------------------------------------------------------------
# Audit HMAC Signing
# ------------------------------------------------------------------
# Separate key from PII so audit signing is independent of PII key rotation.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUDIT_HMAC_KEY=REPLACE_WITH_base64_32_byte_key
