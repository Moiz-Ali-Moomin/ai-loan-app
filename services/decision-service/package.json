{
  "name": "@loan-platform/decision-service",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint src",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "useESM": false }]
    }
  },
  "dependencies": {
    "@nestjs/common": "^10.3.10",
    "@nestjs/core": "^10.3.10",
    "@nestjs/platform-fastify": "^10.3.10",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.1.0",
    "@nestjs/config": "^3.2.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8",
    "axios": "^1.7.2",
    "@loan-platform/shared-types": "^1.0.0",
    "@loan-platform/telemetry": "^1.0.0",
    "@loan-platform/logger": "^1.0.0",
    "@loan-platform/database": "^1.0.0",
    "@loan-platform/kafka": "^1.0.0",
    "@opentelemetry/api": "1.9.0",
    "fastify": "^4.27.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "@temporalio/activity": "^1.11.0",
    "redis": "^4.7.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "typescript": "^5.4.5",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "@types/jsonwebtoken": "^9.0.6",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.13",
    "ts-jest": "^29.2.5"
  }
}
