{
  "name": "ai-loan-governance-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade AI Governance Platform for loan approval in regulated fintechs",
  "workspaces": [
    "packages/*",
    "services/*",
    "frontend"
  ],
  "scripts": {
    "dev": "docker-compose -f infra/docker/docker-compose.yml up -d && turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "npx tsx tests/e2e/loan-flow.e2e.ts",
    "db:migrate": "turbo run db:migrate",
    "infra:up": "docker-compose -f infra/docker/docker-compose.yml up -d",
    "infra:down": "docker-compose -f infra/docker/docker-compose.yml down",
    "infra:logs": "docker-compose -f infra/docker/docker-compose.yml logs -f",
    "seed": "turbo run seed",
    "prisma:generate": "turbo run db:generate",
    "prisma:migrate:dev": "npm run db:migrate:dev -w packages/database",
    "prisma:migrate:deploy": "turbo run db:migrate:deploy",
    "prisma:studio": "npm run db:studio -w packages/database"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.4",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/sdk-node": "0.52.1",
    "@opentelemetry/sdk-metrics": "1.25.1",
    "@opentelemetry/sdk-logs": "0.52.1",
    "@opentelemetry/sdk-trace-base": "1.25.1",
    "@opentelemetry/sdk-trace-node": "1.25.1",
    "@opentelemetry/resources": "1.25.1",
    "@opentelemetry/semantic-conventions": "1.25.1",
    "@opentelemetry/core": "1.25.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.52.1",
    "@opentelemetry/exporter-metrics-otlp-http": "0.52.1",
    "@opentelemetry/exporter-logs-otlp-http": "0.52.1",
    "@opentelemetry/instrumentation": "0.52.1",
    "@opentelemetry/auto-instrumentations-node": "0.48.0"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
