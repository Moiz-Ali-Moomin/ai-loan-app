{
  "name": "ai-loan-governance-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade AI Governance Platform for loan approval in regulated fintechs",
  "workspaces": [
    "packages/*",
    "services/*",
    "frontend"
  ],
  "scripts": {
    "dev": "docker-compose -f infra/docker/docker-compose.yml up -d && turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "turbo run db:migrate",
    "infra:up": "docker-compose -f infra/docker/docker-compose.yml up -d",
    "infra:down": "docker-compose -f infra/docker/docker-compose.yml down",
    "infra:logs": "docker-compose -f infra/docker/docker-compose.yml logs -f",
    "seed": "turbo run seed"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.0"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "@types/node": "^22.0.0",
    "eslint": "^9.3.0",
    "prettier": "^3.2.5",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.4"
  },
  "overrides": {
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/sdk-metrics": "1.25.1",
    "@opentelemetry/sdk-logs": "0.52.1",
    "@opentelemetry/resources": "1.25.1",
    "@opentelemetry/semantic-conventions": "1.25.1",
    "@opentelemetry/core": "1.25.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
