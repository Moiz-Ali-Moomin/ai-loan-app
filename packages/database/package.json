{
  "name": "@loan-platform/database",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "db:migrate": "node dist/migrate.js",
    "seed": "node dist/seed.js",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:introspect": "prisma db pull --schema=./prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema=./prisma/schema.prisma",
    "db:baseline": "prisma migrate resolve --applied 0_init --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "db:validate": "prisma validate --schema=./prisma/schema.prisma",
    "db:format": "prisma format --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "pg": "^8.11.5",
    "postgres": "^3.4.4",
    "@loan-platform/shared-types": "^1.0.0",
    "@loan-platform/logger": "^1.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.6",
    "prisma": "^6.8.2",
    "typescript": "^5.4.5"
  },
  "prisma": {
    "seed": "node dist/seed.js"
  }
}
