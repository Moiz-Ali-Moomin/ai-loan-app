# =============================================================
# AI Loan Governance Platform — Environment Variables
# Copy to .env and fill in values for local development
# =============================================================

# Node
NODE_ENV=development

# API Gateway
API_GATEWAY_PORT=3000
API_GATEWAY_HOST=0.0.0.0
JWT_SECRET=change-me-super-secret-jwt-key-min-32-chars
JWT_EXPIRY=24h
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW=60000

# PostgreSQL
DATABASE_URL=postgresql://loanapp:loanapp_pass@localhost:5432/loandb
POSTGRES_USER=loanapp
POSTGRES_PASSWORD=loanapp_pass
POSTGRES_DB=loandb

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=loan:

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=loan-platform
KAFKA_GROUP_ID_AUDIT=audit-consumer-group
KAFKA_GROUP_ID_EVENTS=event-consumer-group

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=loan-governance
TEMPORAL_TASK_QUEUE=loan-approval

# Open Policy Agent
OPA_URL=http://localhost:8181
OPA_BUNDLE_PATH=/policies

# AI Execution Service
AI_SERVICE_PORT=3003
OPENAI_API_KEY=sk-mock-key-replace-with-real
AI_MODEL=gpt-4o
AI_MAX_TOKENS=2048
AI_MOCK_MODE=true

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PROMPTS=ai-prompts
MINIO_BUCKET_RESPONSES=ai-responses
MINIO_BUCKET_SNAPSHOTS=workflow-snapshots
MINIO_BUCKET_COMPLIANCE=compliance-artifacts

# OpenTelemetry
OTEL_SERVICE_NAME=loan-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# Grafana / LGTM
GRAFANA_PORT=3100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
LOKI_URL=http://localhost:3200
TEMPO_URL=http://localhost:3201
PROMETHEUS_URL=http://localhost:9091

# Service Ports
WORKFLOW_SERVICE_PORT=3001
POLICY_SERVICE_PORT=3002
AUDIT_SERVICE_PORT=3004
EVENT_CONSUMER_PORT=3005
FRONTEND_PORT=3006

# Workflow Config
WORKFLOW_MAX_RETRIES=3
WORKFLOW_EXECUTION_TIMEOUT=3600
HUMAN_APPROVAL_TIMEOUT=86400
HIGH_RISK_THRESHOLD=0.75
LOAN_AMOUNT_MANUAL_THRESHOLD=500000
