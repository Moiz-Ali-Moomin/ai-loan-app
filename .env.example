# =============================================================
# AI Loan Governance Platform — Environment Variables
# Copy to .env and fill in values for local development
# =============================================================

# Node
NODE_ENV=development

# API Gateway
API_GATEWAY_PORT=3000
API_GATEWAY_HOST=0.0.0.0
JWT_SECRET=change-me-super-secret-jwt-key-min-32-chars
JWT_EXPIRY=24h
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW=60000

# PostgreSQL
# docker-compose.dev.yml uses: postgresql://postgres:postgres@postgres:5432/ai_loan_app
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_loan_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_loan_app

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=loan:

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=loan-platform
KAFKA_GROUP_ID_AUDIT=audit-consumer-group
KAFKA_GROUP_ID_EVENTS=event-consumer-group

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=loan-governance
TEMPORAL_TASK_QUEUE=loan-approval

# Open Policy Agent
OPA_URL=http://localhost:8181
OPA_BUNDLE_PATH=/policies

# AI Execution Service
AI_SERVICE_PORT=3003
ANTHROPIC_API_KEY=sk-ant-replace-with-real
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=2048
AI_MOCK_MODE=true

# Embedding Service (pgvector RAG)
# Provider: local (BGE-small via FastEmbed) | openai (text-embedding-3-small)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Must match the VECTOR(N) dimension in the migration (005_pgvector_rag.sql)
# local BGE-small = 384 | openai text-embedding-3-small = up to 1536 (we use 1024)
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_DELAY_MS=1000
EMBEDDING_TIMEOUT_MS=30000

# FastEmbed server URL — used when EMBEDDING_PROVIDER=local
FASTEMBED_URL=http://fastembed:8000
# FastEmbed model loaded at startup
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5

# OpenAI API key — only required when EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-replace-with-real-openai-key

# RAG Retrieval Configuration
# Cosine similarity threshold: 0.0 = accept everything, 1.0 = exact match only
# 0.72 is a well-calibrated default for fintech compliance text
RAG_SIMILARITY_THRESHOLD=0.72
# Maximum chunks returned per query
RAG_TOP_K=8
# Maximum tokens of context injected into the system prompt
RAG_MAX_CONTEXT_TOKENS=6000

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PROMPTS=ai-prompts
MINIO_BUCKET_RESPONSES=ai-responses
MINIO_BUCKET_SNAPSHOTS=workflow-snapshots
MINIO_BUCKET_COMPLIANCE=compliance-artifacts

# OpenTelemetry
OTEL_SERVICE_NAME=loan-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# Grafana / LGTM
GRAFANA_PORT=3100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
LOKI_URL=http://localhost:3200
TEMPO_URL=http://localhost:3201
PROMETHEUS_URL=http://localhost:9091

# Service Ports
WORKFLOW_SERVICE_PORT=3001
POLICY_SERVICE_PORT=3002
AUDIT_SERVICE_PORT=3004
EVENT_CONSUMER_PORT=3005
FRONTEND_PORT=3006

# Workflow Config
WORKFLOW_MAX_RETRIES=3
WORKFLOW_EXECUTION_TIMEOUT=3600
HUMAN_APPROVAL_TIMEOUT=86400
HIGH_RISK_THRESHOLD=0.75
LOAN_AMOUNT_MANUAL_THRESHOLD=500000
